# =============================================================================
# QWE COMMUNITY — Environment Variables Template
# Copy this file to .env and fill in all values before running the project.
# NEVER commit your actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# PostgreSQL connection string.
# On Replit this is auto-provisioned. On Railway/VPS provision a Postgres DB.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/qwe_community

# -----------------------------------------------------------------------------
# JWT / SESSION SECRET (Required)
# A long random string used to sign JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
SESSION_SECRET=your_super_secret_jwt_key_change_this_in_production

# -----------------------------------------------------------------------------
# ADMIN ACCOUNT (Required for seed script)
# Password for the initial admin account (gameransh2434@gmail.com).
# Used by: pnpm --filter @workspace/scripts run seed-admin
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=your_admin_password_here

# -----------------------------------------------------------------------------
# SMTP / EMAIL (Required for OTP verification emails)
# Gmail SMTP credentials. Use an App Password, not your real Gmail password.
# Steps: Google Account → Security → 2-Step Verification → App Passwords
# If missing, the server falls back to logging OTPs to console (dev only).
# -----------------------------------------------------------------------------
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_16_chars

# -----------------------------------------------------------------------------
# SERVER PORT (Optional — set by platform automatically)
# The port the API server listens on. Defaults to 8080 on Replit.
# On Railway/Render/VPS this is injected automatically.
# -----------------------------------------------------------------------------
PORT=8080

# -----------------------------------------------------------------------------
# FRONTEND BUILD (Optional — Replit/Vite specific)
# BASE_PATH: URL path prefix for the frontend (default "/").
# REPLIT_DOMAINS: Comma-separated public domain(s) — used to inject OG image URLs.
# REPLIT_DEV_DOMAIN: Dev tunnel domain — fallback for OG image URL in development.
# These are injected automatically by Replit. For VPS/Railway set REPLIT_DOMAINS
# to your actual domain, e.g. REPLIT_DOMAINS=qwe-community.up.railway.app
# -----------------------------------------------------------------------------
BASE_PATH=/
REPLIT_DOMAINS=your-app.up.railway.app
# REPLIT_DEV_DOMAIN=   # (Replit dev only, not needed on other platforms)
